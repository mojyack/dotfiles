include fragments/suspend-binds

set $backlight intel
include fragments/brightness-mediakey

output eDP-1 {
    scale 1.5
}

input 2:10:TPPS/2_Elan_TrackPoint {
    accel_profile "flat"
    pointer_accel 0.6
}

input 1739:0:Synaptics_TM3383-002 {
    pointer_accel 0.7
    scroll_factor 1.0
    natural_scroll enabled
    tap enabled
}
