set $backlight dsi
include fragments/brightness-mediakey

output DSI-1 scale 2
input 1739:0:Synaptics_S3706B map_to_output DSI-1

bindsym --release XF86PowerOff output DSI-1 dpms toggle; input 1739:0:Synaptics_S3706B events toggle
bindsym --release XF86PowerOff+XF86AudioRaiseVolume input 1739:0:Synaptics_S3706B events toggle
bindsym --release XF86AudioRaiseVolume+XF86AudioLowerVolume exec /usr/local/bin/suspend

bindsym --input-device=0:0:Alert_slider 1 exec switch-screen-rotate
bindsym --input-device=0:0:Alert_slider 2 exec switch-screen-rotate
bindsym --input-device=0:0:Alert_slider 3 fullscreen disable
