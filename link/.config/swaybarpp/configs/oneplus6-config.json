{
    "height": 40,
    "position": "top",
    "font": "Noto Sans CJK JP, Font Awesome 6 Free 10",
    "background": "#2e3440",
    "foreground": "#e5e9f0",

    "mods_left": {
        "padding": {"size":8},
        "workspace": {},
        "cpu_usage": {"format": " {}%", "on_click": ["switch-screen-rotate"]},
        "ram_usage": {"format": " {}G", "on_click": ["switch-screen-rotate"]},
        "padding": {"size":32, "on_click": ["doas", "suspend"]},
    },
    "mods_right": {
        "padding": {"size":8, "on_click": ["switch-wvkbd"]},
        "datetime": {"format": "%H:%M", "on_click": ["switch-wvkbd"]},
        "battery": {"name": "bq27411-0", "format": " {}%", "style": "graph", "size": 0.3},
        "network": {"wired": "", "wireless": "", "offline": "⚠", "on_click": ["swaybarpp-brightness", "/sys/class/backlight/ae94000.dsi.0"]},
        "pipewire": {"format": "", "format_muted": "", "on_click": ["swaybarpp-volume"]},
    },
}
